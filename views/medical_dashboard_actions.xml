<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
         <!-- Define the Dashboard Client Action linked to an OWL Tag -->
        <record id="action_medical_dashboard" model="ir.actions.client">
            <field name="name">Medical Dashboard</field>
            <field name="tag">medical_dashboard_client_action</field>
        </record>
        <record id="action_reception_dashboard_owl" model="ir.actions.client">
            <field name="name">Reception Dashboard</field>
            <field name="tag">ekram_medical_reception_dashboard</field>
        </record>
        <record id="action_doctor_dashboard_owl" model="ir.actions.client">
            <field name="name">Doctor Dashboard</field>
            <field name="tag">ekram_medical_doctor_dashboard</field>
        </record>
        <record id="action_lab_dashboard_owl" model="ir.actions.client">
            <field name="name">Laboratory Dashboard</field>
            <field name="tag">ekram_medical_lab_dashboard</field>
        </record>
        <record id="action_admin_dashboard_owl" model="ir.actions.client">
            <field name="name">Admin Dashboard</field>
            <field name="tag">ekram_medical_admin_dashboard</field>
        </record>
    </data>
</odoo>