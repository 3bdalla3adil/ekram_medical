<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- <data> -->
        <!-- ── Form View ───────────────────────────────────────────────── -->
        <record id="view_medical_appointment_form" model="ir.ui.view">
            <field name="name">medical.appointment.form</field>
            <field name="model">medical.appointment</field>
            <field name="arch" type="xml">
                <form string="Appointment">
                    <header>
                        <button class="btn-primary" invisible="state != 'draft'" name="action_confirm" string="Confirm" type="object"/>
                        <button class="btn-primary" invisible="state != 'confirmed'" name="action_start" string="Start" type="object"/>
                        <button class="btn-success" invisible="state not in ['confirmed', 'in_progress']" name="action_create_consultation" string="Create Consultation" type="object"/>
                        <button invisible="state != 'in_progress'" name="action_done" string="Mark Done" type="object"/>
                        <button invisible="state in ['done', 'cancelled']" name="action_cancel" string="Cancel" type="object"/>
                        <button invisible="state != 'cancelled'" name="action_reset_draft" string="Reset to Draft" type="object"/>
                        <field name="state" statusbar_visible="draft,confirmed,in_progress,done" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Patient">
                                <field name="patient_id" options="{'no_create': True}"/>
                                <field name="doctor_id"/>
                                <field name="appointment_type"/>
                            </group>
                            <group string="Schedule">
                                <field name="appointment_date"/>
                                <field groups="base.group_multi_company" name="company_id"/>
                            </group>
                        </group>
                        <group string="Details">
                            <field name="chief_complaint" placeholder="Chief complaint..."/>
                            <field name="notes" placeholder="Additional notes..."/>
                        </group>
                        <group invisible="consultation_id == False" string="Consultation">
                            <field name="consultation_id" readonly="1"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form></field>
        </record>
        <!-- ── List View ───────────────────────────────────────────────── -->
        <record id="view_medical_appointment_list" model="ir.ui.view">
            <field name="name">medical.appointment.list</field>
            <field name="model">medical.appointment</field>
            <field name="arch" type="xml">
                <list decoration-muted="state == 'cancelled'" decoration-success="state == 'done'" decoration-warning="state == 'in_progress'" string="Appointments">
                    <field name="name"/>
                    <field name="patient_id"/>
                    <field name="doctor_id"/>
                    <field name="appointment_date"/>
                    <field name="appointment_type"/>
                    <field decoration-info="state == 'confirmed'" decoration-muted="state == 'cancelled'" decoration-success="state == 'done'" decoration-warning="state == 'in_progress'" name="state" widget="badge"/>
                </list></field>
        </record>
        <!-- ── Kanban View ─────────────────────────────────────────────── -->
        <record id="view_medical_appointment_kanban" model="ir.ui.view">
            <field name="name">medical.appointment.kanban</field>
            <field name="model">medical.appointment</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_small_column o_kanban_project_tasks" default_group_by="state" quick_create="false">
                <!-- Fetch all required context fields into browser memory -->
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="appointment_date"/>
                <field name="state"/>
                <field name="appointment_type"/>
                
                <templates>
                    <t t-name="card">
                        <field name="name" class="fw-bold fs-5"/>
                        <field name="patient_id"/>
                        <field name="state" />
                        <footer class="pt-1 mt-0">
                            <div class="d-flex mt-auto">
                                <field name="appointment_type" class="me-2"/>
                                <field name="activity_ids" widget="kanban_activity"/>
                            </div>
                            <field name="doctor_id" widget="many2one_avatar_user" class="ms-auto"/>
                        </footer>
                    </t>
                    </templates>
            </kanban>
            </field>
        </record>
        <!-- ── Search View ─────────────────────────────────────────────── -->
        <record id="view_medical_appointment_search" model="ir.ui.view">
            <field name="name">medical.appointment.search</field>
            <field name="model">medical.appointment</field>
            <field name="arch" type="xml">
                <search string="Search Appointments">
                    <field name="name"/>
                    <field name="patient_id"/>
                    <field name="doctor_id"/>
                    <separator/>
                    <filter domain="[('appointment_date', '>=', datetime.datetime.now().strftime('%Y-%m-%d 00:00:00')),                                      ('appointment_date', '&lt;=', datetime.datetime.now().strftime('%Y-%m-%d 23:59:59'))]" name="filter_today" string="Today"/>
                    <filter domain="[('state', '=', 'draft')]" name="filter_draft" string="Scheduled"/>
                    <filter domain="[('state', '=', 'confirmed')]" name="filter_confirmed" string="Confirmed"/>
                    <filter domain="[('state', '=', 'in_progress')]" name="filter_in_progress" string="In Progress"/>
                    <filter domain="[('state', '=', 'done')]" name="filter_done" string="Done"/>
                    <filter domain="[('state', '=', 'cancelled')]" name="filter_cancelled" string="Cancelled"/>
                    <group>
                        <filter context="{'group_by': 'doctor_id'}" name="group_doctor" string="Doctor"/>
                        <filter context="{'group_by': 'state'}" name="group_state" string="Status"/>
                        <filter context="{'group_by': 'appointment_date:day'}" name="group_date" string="Date"/>
                    </group>
                </search></field>
        </record>
        <!-- ── Action ──────────────────────────────────────────────────── -->
        <record id="action_medical_appointments" model="ir.actions.act_window">
            <field name="name">Appointments</field>
            <field name="res_model">medical.appointment</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="context">{'search_default_filter_today': 1}</field>
        </record>

    <!--=================================================================================-->

    <!-- Keep your existing Appointment menu but put it under the same root -->
    <record id="action_medical_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">medical.appointment</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <!-- </data> -->
</odoo>
