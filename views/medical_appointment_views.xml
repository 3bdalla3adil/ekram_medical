<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ── Form View ───────────────────────────────────────────────── -->
        <record id="view_medical_appointment_form" model="ir.ui.view">
            <field name="name">medical.appointment.form</field>
            <field name="model">medical.appointment</field>
            <field name="arch" type="xml">
                <form string="Appointment">
                    <header>
                        <button class="btn-primary" invisible="state != 'draft'" name="action_confirm" string="Confirm" type="object"/>
                        <button class="btn-primary" invisible="state != 'confirmed'" name="action_start" string="Start" type="object"/>
                        <button class="btn-success" invisible="state not in ['confirmed', 'in_progress']" name="action_create_consultation" string="Create Consultation" type="object"/>
                        <button invisible="state != 'in_progress'" name="action_done" string="Mark Done" type="object"/>
                        <button invisible="state in ['done', 'cancelled']" name="action_cancel" string="Cancel" type="object"/>
                        <button invisible="state != 'cancelled'" name="action_reset_draft" string="Reset to Draft" type="object"/>
                        <field name="state" statusbar_visible="draft,confirmed,in_progress,done" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Patient">
                                <field name="patient_id" options="{'no_create': True}"/>
                                <field name="doctor_id"/>
                                <field name="appointment_type"/>
                            </group>
                            <group string="Schedule">
                                <field name="appointment_date"/>
                                <field groups="base.group_multi_company" name="company_id"/>
                            </group>
                        </group>
                        <group string="Details">
                            <field name="chief_complaint" placeholder="Chief complaint..."/>
                            <field name="notes" placeholder="Additional notes..."/>
                        </group>
                        <group invisible="consultation_id == False" string="Consultation">
                            <field name="consultation_id" readonly="1"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form></field>
        </record>
        <!-- ── List View ───────────────────────────────────────────────── -->
        <record id="view_medical_appointment_list" model="ir.ui.view">
            <field name="name">medical.appointment.list</field>
            <field name="model">medical.appointment</field>
            <field name="arch" type="xml">
                <list decoration-muted="state == 'cancelled'" decoration-success="state == 'done'" decoration-warning="state == 'in_progress'" string="Appointments">
                    <field name="name"/>
                    <field name="patient_id"/>
                    <field name="doctor_id"/>
                    <field name="appointment_date"/>
                    <field name="appointment_type"/>
                    <field decoration-info="state == 'confirmed'" decoration-muted="state == 'cancelled'" decoration-success="state == 'done'" decoration-warning="state == 'in_progress'" name="state" widget="badge"/>
                </list></field>
        </record>
        <!-- ── Kanban View ─────────────────────────────────────────────── -->
        <record id="view_medical_appointment_kanban" model="ir.ui.view">
            <field name="name">medical.appointment.kanban</field>
            <field name="model">medical.appointment</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_small_column o_kanban_project_tasks" default_group_by="state" quick_create="false">
                <!-- Fetch all required context fields into browser memory -->
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="appointment_date"/>
                <field name="state"/>
                <field name="appointment_type"/>
                
                <templates>
                    <t t-name="kanban-box">
                        <!-- Standard EMR Clickable Card with left image spacing layout -->
                        <div class="oe_kanban_global_click o_kanban_record d-flex flex-column p-3 bg-white border rounded shadow-sm hover-elevate">
                            
                            <!-- UPPER FRAME: Patient Title & Quick Dropdown Settings Context Menu -->
                            <div class="o_kanban_record_top d-flex align-items-start justify-content-between mb-2">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title fs-5 text-dark fw-bold">
                                        <field name="patient_id"/>
                                    </strong>
                                    <div class="text-muted small mt-1">
                                        <i class="fa fa-hashtag me-1"/> <field name="name"/>
                                    </div>
                                </div>
                                <!-- Dropdown widget context menu wrapper -->
                                <div class="o_dropdown_kanban dropdown">
                                    <a class="dropdown-toggle btn btn-sm text-muted" data-bs-toggle="dropdown" href="#" role="button">
                                        <span class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                        <t t-if="widget.editable"><a type="edit" class="dropdown-item">Edit Details</a></t>
                                        <t t-if="widget.deletable"><a type="delete" class="dropdown-item text-danger">Delete Appointment</a></t>
                                    </div>
                                </div>
                            </div>

                            <!-- MAIN FRAME: Split Image and Clinical Metadata View Columns -->
                            <div class="o_kanban_record_body d-flex gap-3 my-2 align-items-center">
                                <!-- Left Section: EMR Profile Thumbnail Icon -->
                                <div class="o_kanban_image_container bg-100 rounded d-flex align-items-center justify-content-center border" style="width: 48px; height: 48px; min-width: 48px;">
                                    <!-- Dynamic fallback using standard Odoo contact asset profile styling strings -->
                                    <img t-att-src="kanban_image('res.partner', 'avatar_128', record.patient_id.raw_value)" 
                                         alt="Patient Avatar" 
                                         class="o_image_64_max rounded-circle object-fit-cover" 
                                         style="width: 42px; height: 42px;"/>
                                </div>

                                <!-- Right Section: Assignment Metadata Rows -->
                                <div class="d-flex flex-column gap-1 text-secondary small w-100">
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="fa fa-user-md text-primary" style="width: 14px;" title="Attending Doctor"/>
                                        <span class="fw-semibold"><field name="doctor_id"/></span>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="fa fa-calendar text-info" style="width: 14px;" title="Scheduled Date"/>
                                        <span><field name="appointment_date"/></span>
                                    </div>
                                </div>
                            </div>

                            <!-- LOWER FRAME: Appointment Categorization Badge & Colored Pipeline Flow Status -->
                            <div class="o_kanban_record_bottom d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
                                <div class="oe_kanban_bottom_left">
                                    <!-- Appointment Type categorization tag badge wrapper -->
                                    <span class="badge rounded-pill bg-light text-dark border px-2 py-1">
                                        <i class="fa fa-tags text-muted me-1 small"/> <field name="appointment_type"/>
                                    </span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <!-- Operational flow colored status badge matching your mapping logic -->
                                    <field name="state"
                                           options="{'classes': {
                                               'draft': 'bg-secondary text-white',
                                               'confirmed': 'bg-info text-white',
                                               'in_progress': 'bg-warning text-dark',
                                               'done': 'bg-success text-white',
                                               'cancelled': 'bg-danger text-white'
                                           }}"
                                           widget="label_selection"/>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
                 <!-- <kanban class="o_kanban_small_column" default_group_by="state">
                    <field name="name"/>
                    <field name="patient_id"/>
                    <field name="doctor_id"/>
                    <field name="appointment_date"/>
                    <field name="state"/>
                    <field name="appointment_type"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                                <div class="oe_kanban_content">
