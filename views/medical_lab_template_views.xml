<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_medical_lab_template_form" model="ir.ui.view">
            <field name="name">medical.lab.template.form</field>
            <field name="model">medical.lab.template</field>
            <field name="arch" type="xml">
                <form string="Lab Template">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button type="object" name="action_view_template_lines"
                                    class="oe_stat_button" icon="fa-list">
                                <field name="line_count" widget="statinfo" string="Parameters"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="Investigation Name..."/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="code"/>
                                <field name="product_id"/>
                                <field name="department"/>
                            </group>
                            <group>
                                <field name="sample_type"/>
                                <field name="turnaround_hours"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <field name="notes" placeholder="Notes..."/>
                        <notebook>
                            <page string="Parameters" name="parameters">
                                <field name="line_ids">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="test_name"/>
                                        <field name="unit"/>
                                        <field name="normal_range_text"/>
                                        <field name="normal_min"/>
                                        <field name="normal_max"/>
                                        <field name="result_type"/>
                                        <field name="notes"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_medical_lab_template_list" model="ir.ui.view">
            <field name="name">medical.lab.template.list</field>
            <field name="model">medical.lab.template</field>
            <field name="arch" type="xml">
                <list string="Lab Templates">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="department"/>
                    <field name="sample_type"/>
                    <field name="line_count" string="Parameters"/>
                    <field name="turnaround_hours"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="action_medical_lab_templates" model="ir.actions.act_window">
            <field name="name">Lab Templates</field>
            <field name="res_model">medical.lab.template</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>