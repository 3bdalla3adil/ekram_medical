<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_ekram_medical" model="ir.module.category">
            <field name="name">Ekram Medical Center</field>
            <field name="description">Ekram Medical Center Management System</field>
            <field name="sequence">100</field>
        </record>

        <record id="group_medical_reception" model="res.groups">
            <field name="name">Reception</field>
            <!-- <field name="privilege_id" ref="module_category_ekram_medical"/> -->
        </record>

        <record id="group_medical_doctor" model="res.groups">
            <field name="name">Doctor</field>
            <!-- <field name="privilege_id" ref="module_category_ekram_medical"/> -->
        </record>

        <record id="group_medical_lab_technician" model="res.groups">
            <field name="name">Lab Technician</field>
            <!-- <field name="privilege_id" ref="module_category_ekram_medical"/> -->
        </record>

        <record id="group_medical_administrator" model="res.groups">
            <field name="name">Medical Administrator</field>
            <!-- <field name="privilege_id" ref="module_category_ekram_medical"/> -->
            <field name="implied_ids" eval="[
                (4, ref('group_medical_reception')),
                (4, ref('group_medical_doctor')),
                (4, ref('group_medical_lab_technician'))
            ]"/>
        </record>
    </data>
</odoo>