<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_lab_result" model="ir.actions.report">
        <field name="name">Laboratory Report</field>
        <field name="model">medical.lab.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ekram_medical.report_lab_result_template</field>
        <field name="binding_model_id" ref="model_medical_lab_request"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Lab Report - %s' % (object.name)</field>
    </record>

    <!-- ── Patient Card Report ─────────────────────────────────────── -->
    <record id="action_report_patient_card" model="ir.actions.report">
        <field name="name">Patient Card</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ekram_medical.report_patient_card_template</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Patient Card - %s' % (object.name)</field>
    </record>

    <!-- ── Prescription Report ─────────────────────────────────────── -->
    <record id="action_report_prescription" model="ir.actions.report">
        <field name="name">Prescription</field>
        <field name="model">medical.consultation</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ekram_medical.report_prescription_template</field>
        <field name="binding_model_id" ref="model_medical_consultation"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Prescription - %s' % (object.name)</field>
    </record>

